<IfModule mod_headers.c>
  # CSP dopuszczajaca embed YouTube (film w hero) + Google Fonts + Umami.
  # Bez tego host blokuje ramke YouTube: "Ta zawartosc jest zablokowana".
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cloud.umami.is; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://i.ytimg.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; media-src 'self'; connect-src 'self' https://cloud.umami.is; frame-ancestors 'self'"
</IfModule>
